erDiagram
    YAHOO_RAW {
        date date
        string ticker
        float open
        float high
        float low
        float close
        float adj_close
        int volume
    }

    STG_MARKET_PRICES {
        date date
        string ticker
        float close
        int volume
    }

    YAHOO_RAW ||--o{ STG_MARKET_PRICES : "derived (dbt view, select subset of columns)"
